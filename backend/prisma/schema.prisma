generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  TRAINER
}

enum TenantStatus {
  ACTIVE
  TRIAL
  EXPIRED
  SUSPENDED
}

enum TenantSubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

model PlatformPlan {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(120)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  billingCycle String  @db.VarChar(50) @map("billing_cycle")
  features    Json?    @db.JsonB
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenantSubscriptions TenantSubscription[]

  @@map("platform_plans")
}

enum PlanType {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
  CUSTOM
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  PENDING
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MemberSource {
  WALK_IN
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  REFERRAL
  WEBSITE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  MISSED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  MEMBERSHIP_EXPIRING
  MEMBERSHIP_EXPIRED
  PAYMENT_DUE
  PAYMENT_RECEIVED
  SYSTEM
}

model Tenant {
  id             String  @id @default(uuid()) @db.Uuid
  name           String  @db.VarChar(255)
  email          String  @unique @db.VarChar(255)
  phone          String? @db.VarChar(20)
  address        String? @db.Text
  country        String? @db.VarChar(100)
  state          String? @db.VarChar(100)
  city           String? @db.VarChar(100)
  gymLogoUrl     String? @map("gym_logo_url") @db.VarChar(2048)
  gymDescription String? @map("gym_description") @db.Text
  gymWebsite     String? @map("gym_website") @db.VarChar(2048)
  gstNumber      String? @map("gst_number") @db.VarChar(15)
  timezone       String  @default("Asia/Kolkata") @db.VarChar(64)
  currency       String  @default("INR") @db.VarChar(3)
  businessHours  Json?   @map("business_hours")

  status    TenantStatus @default(TRIAL) @map("status")
  isActive  Boolean      @default(true)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users                User[]
  membershipPlans      MembershipPlan[]
  members              Member[]
  attendances          Attendance[]
  subscriptions        Subscription[]
  payments             Payment[]
  invoices             Invoice[]
  notifications        Notification[]
  whatsappLogs         WhatsAppLog[]
  tenantSubscriptions  TenantSubscription[]
  tenantInvoices       TenantInvoice[]

  @@index([deletedAt], name: "idx_tenant_deleted_at")
  @@index([isActive, deletedAt], name: "idx_tenant_active_status")
  @@index([gstNumber], name: "idx_tenant_gst_number")
  @@index([country, state, city], name: "idx_tenant_geo_reporting")
  @@index([country, state, deletedAt], name: "idx_tenant_geo_active_reporting")
  @@index([status, deletedAt], name: "idx_tenant_status_lookup")
  @@index([createdAt, deletedAt], name: "idx_tenant_global_created")
  @@map("tenants")
}

model User {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String? @map("tenant_id") @db.Uuid
  firstName    String  @map("first_name") @db.VarChar(100)
  lastName     String  @map("last_name") @db.VarChar(100)
  email        String  @db.VarChar(255)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  role         Role    @default(TRAINER)

  isActive    Boolean   @default(true)
  lastLoginAt DateTime? @map("last_login_at")

  failedLoginAttempts    Int       @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime? @map("locked_until")
  passwordResetToken     String?   @map("password_reset_token") @db.VarChar(255)
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  attendancesMarked Attendance[] @relation("AttendanceMarkedBy")

  @@unique([tenantId, email], name: "uq_user_tenant_email")
  @@index([tenantId, role, deletedAt], name: "idx_user_tenant_role")
  @@index([tenantId, isActive, deletedAt], name: "idx_user_tenant_active")
  @@index([email, deletedAt], name: "idx_user_email_lookup")
  @@index([deletedAt], name: "idx_user_deleted_at")
  @@index([role], name: "idx_user_role")
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  familyId   String    @map("family_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  userAgent  String?   @map("user_agent") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], name: "idx_refresh_token_user")
  @@index([expiresAt], name: "idx_refresh_token_expiry")
  @@index([familyId], name: "idx_refresh_token_family")
  @@map("refresh_tokens")
}

model MembershipPlan {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(120)
  description  String?  @db.Text
  planType     PlanType @map("plan_type")
  durationDays Int      @map("duration_days")
  price        Decimal  @db.Decimal(10, 2)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([tenantId, deletedAt], name: "idx_membership_plan_tenant_deleted")
  @@index([tenantId, isActive, deletedAt], name: "idx_membership_plan_tenant_active")
  @@index([tenantId, name, deletedAt], name: "idx_membership_plan_tenant_name")
  @@index([tenantId, durationDays, deletedAt], name: "idx_membership_plan_tenant_duration")
  @@index([tenantId, planType, deletedAt], name: "idx_membership_plan_tenant_type")
  @@index([tenantId, displayOrder, deletedAt], name: "idx_membership_plan_tenant_display")
  @@index([tenantId, isActive, displayOrder, deletedAt], name: "idx_membership_plan_tenant_catalog")
  @@map("membership_plans")
}

model Member {
  id String @id @default(uuid()) @db.Uuid

  tenantId   String @map("tenant_id") @db.Uuid
  memberCode String @db.VarChar(50)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendances  Attendance[]
  subscriptions Subscription[]
  payments      Payment[]
  invoices      Invoice[]
  notifications Notification[]
  whatsappLogs  WhatsAppLog[]

  firstName   String    @map("first_name") @db.VarChar(100)
  lastName    String    @map("last_name") @db.VarChar(100)
  email       String    @db.VarChar(255)
  phone       String    @db.VarChar(20)
  gender      Gender
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  photoUrl    String?   @map("photo_url") @db.VarChar(2048)

  emergencyContactName     String @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactPhone    String @map("emergency_contact_phone") @db.VarChar(20)
  emergencyContactRelation String @map("emergency_contact_relation") @db.VarChar(100)

  heightCm    Decimal? @map("height_cm") @db.Decimal(5, 2)
  weightKg    Decimal? @map("weight_kg") @db.Decimal(5, 2)
  fitnessGoal String?  @map("fitness_goal") @db.VarChar(255)
  notes       String?  @db.Text

  source MemberSource?

  occupation String? @db.VarChar(100)

  bloodGroup BloodGroup?

  status   MemberStatus @default(ACTIVE)
  isActive Boolean      @default(true)

  joinedAt  DateTime  @default(now()) @map("joined_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, memberCode], name: "uq_member_tenant_code")
  @@unique([tenantId, id], name: "uq_member_tenant_id")
  @@index([tenantId, isActive, deletedAt], name: "idx_member_tenant_active")
  @@index([tenantId, status, deletedAt], name: "idx_member_tenant_status")
  @@index([tenantId, joinedAt, deletedAt], name: "idx_member_tenant_joined")
  @@index([tenantId, phone, deletedAt], name: "idx_member_tenant_phone")
  @@index([tenantId, lastName, firstName, deletedAt], name: "idx_member_tenant_name")
  @@index([tenantId, fitnessGoal, deletedAt], name: "idx_member_tenant_fitness_goal")
  @@index([tenantId, status, isActive, deletedAt], name: "idx_member_tenant_status_active")
  @@index([tenantId, source, deletedAt], name: "idx_member_tenant_source")
  @@index([tenantId, occupation, deletedAt], name: "idx_member_tenant_occupation")
  @@index([tenantId, bloodGroup, deletedAt], name: "idx_member_tenant_blood_group")
  @@index([tenantId, createdAt, deletedAt], name: "idx_member_tenant_created")
  @@index([tenantId, email, deletedAt], name: "idx_member_tenant_email")
  @@index([memberCode], name: "idx_member_code")
  @@index([deletedAt], name: "idx_member_deleted_at")
  @@map("members")
}

model Attendance {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  memberId         String          @map("member_id") @db.Uuid
  markedByUserId   String?         @map("marked_by_user_id") @db.Uuid
  checkInAt        DateTime        @map("check_in_at") @db.Timestamptz(6)
  checkOutAt       DateTime?       @map("check_out_at") @db.Timestamptz(6)
  attendanceDate   DateTime        @map("attendance_date") @db.Date // Calendar date only, for daily/monthly reporting
  status           AttendanceStatus
  notes            String?         @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member   Member  @relation(fields: [tenantId, memberId], references: [tenantId, id], onDelete: Cascade)
  markedBy User?   @relation("AttendanceMarkedBy", fields: [markedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, memberId, deletedAt], name: "idx_attendance_tenant_member")
  @@index([tenantId, memberId, checkInAt, deletedAt], name: "idx_attendance_tenant_member_checkin")
  @@index([tenantId, status, deletedAt], name: "idx_attendance_tenant_status")
  @@index([tenantId, checkInAt, deletedAt], name: "idx_attendance_tenant_checkin")
  @@index([tenantId, checkInAt, status], name: "idx_attendance_tenant_checkin_status")
  @@index([tenantId, attendanceDate, deletedAt], name: "idx_attendance_tenant_date") // Daily reporting
  @@index([tenantId, attendanceDate, memberId, deletedAt], name: "idx_attendance_tenant_date_member") // Daily member reporting
  @@index([markedByUserId, deletedAt], name: "idx_attendance_marked_by_user") // Audit queries
  @@index([memberId, deletedAt], name: "idx_member_attendance_lookup")
  @@index([checkInAt, deletedAt], name: "idx_attendance_checkin_date")
  @@index([tenantId, createdAt, deletedAt], name: "idx_attendance_tenant_created")
  @@index([tenantId, memberId, checkOutAt, deletedAt], name: "idx_attendance_active_checkin")
  @@map("attendances")
}

model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  memberId         String             @map("member_id") @db.Uuid
  membershipPlanId String             @map("membership_plan_id") @db.Uuid
  startDate        DateTime           @map("start_date") @db.Date
  endDate          DateTime           @map("end_date") @db.Date
  amount           Decimal            @db.Decimal(10, 2)
  status           SubscriptionStatus @default(PENDING)
  autoRenew        Boolean            @default(false) @map("auto_renew")
  notes            String?            @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member         Member         @relation(fields: [tenantId, memberId], references: [tenantId, id], onDelete: Cascade)
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id], onDelete: Restrict)
  payments       Payment[]
  invoices       Invoice[]

  @@index([tenantId, deletedAt], name: "idx_subscription_tenant_deleted")
  @@index([tenantId, memberId, deletedAt], name: "idx_subscription_tenant_member")
  @@index([tenantId, status, deletedAt], name: "idx_subscription_tenant_status")
  @@index([tenantId, endDate, deletedAt], name: "idx_subscription_tenant_end_date")
  @@index([membershipPlanId], name: "idx_subscription_plan")
  @@index([tenantId, createdAt, deletedAt], name: "idx_subscription_tenant_created")
  @@map("subscriptions")
}

model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  tenantId             String        @map("tenant_id") @db.Uuid
  memberId             String        @map("member_id") @db.Uuid
  subscriptionId       String?       @map("subscription_id") @db.Uuid
  amount               Decimal       @db.Decimal(10, 2)
  paymentMethod        PaymentMethod @map("payment_method")
  paymentStatus        PaymentStatus @map("payment_status")
  transactionReference String?       @map("transaction_reference") @db.VarChar(100)

  razorpayOrderId      String?       @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId    String?       @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature    String?       @map("razorpay_signature") @db.VarChar(255)
  gateway              String?       @db.VarChar(50)
  gatewayStatus        String?       @map("gateway_status") @db.VarChar(50)
  gatewayPayload       Json?         @map("gateway_payload") @db.JsonB

  paidAt               DateTime?     @map("paid_at") @db.Timestamptz(6)
  notes                String?       @db.Text

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member       Member        @relation(fields: [tenantId, memberId], references: [tenantId, id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@index([tenantId, deletedAt], name: "idx_payment_tenant_deleted")
  @@index([tenantId, memberId, deletedAt], name: "idx_payment_tenant_member")
  @@index([tenantId, paymentStatus, deletedAt], name: "idx_payment_tenant_status")
  @@index([tenantId, paidAt, deletedAt], name: "idx_payment_tenant_paid_at")
  @@index([subscriptionId], name: "idx_payment_subscription")
  @@index([tenantId, createdAt, deletedAt], name: "idx_payment_tenant_created")
  @@map("payments")
}

model Invoice {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  memberId       String   @map("member_id") @db.Uuid
  subscriptionId String?  @map("subscription_id") @db.Uuid
  paymentId      String?  @map("payment_id") @db.Uuid
  invoiceNumber  String   @map("invoice_number") @db.VarChar(50)
  amount         Decimal  @db.Decimal(10, 2)
  issuedAt       DateTime @default(now()) @map("issued_at") @db.Timestamptz(6)
  notes          String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member       Member        @relation(fields: [tenantId, memberId], references: [tenantId, id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment      Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([tenantId, invoiceNumber], name: "uq_invoice_tenant_number")
  @@index([tenantId, memberId], name: "idx_invoice_tenant_member")
  @@index([tenantId, issuedAt], name: "idx_invoice_tenant_issued_at")
  @@index([subscriptionId], name: "idx_invoice_subscription")
  @@index([paymentId], name: "idx_invoice_payment")
  @@map("invoices")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  memberId  String           @map("member_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?            @db.JsonB
  
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member           @relation(fields: [tenantId, memberId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId], name: "idx_notification_tenant")
  @@index([tenantId, memberId], name: "idx_notification_tenant_member")
  @@index([tenantId, isRead], name: "idx_notification_tenant_is_read")
  @@index([tenantId, type], name: "idx_notification_tenant_type")
  @@index([tenantId, createdAt], name: "idx_notification_tenant_created_at")
  @@map("notifications")
}

model TenantSubscription {
  id              String                   @id @default(uuid()) @db.Uuid
  tenantId        String                   @map("tenant_id") @db.Uuid
  platformPlanId  String                   @map("platform_plan_id") @db.Uuid
  status          TenantSubscriptionStatus   @default(PENDING)
  startDate       DateTime                 @map("start_date") @db.Date
  endDate         DateTime                 @map("end_date") @db.Date
  autoRenew       Boolean                  @default(false) @map("auto_renew")
  trialEndsAt     DateTime?                @map("trial_ends_at") @db.Date
  cancelledAt     DateTime?                @map("cancelled_at") @db.Timestamptz(6)
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformPlan PlatformPlan @relation(fields: [platformPlanId], references: [id], onDelete: Restrict)
  invoices     TenantInvoice[]

  @@index([tenantId, status], name: "idx_tenant_sub_tenant_status")
  @@index([tenantId, endDate], name: "idx_tenant_sub_tenant_end_date")
  @@index([status], name: "idx_tenant_sub_global_status")
  @@map("tenant_subscriptions")
}

model TenantInvoice {
  id                   String        @id @default(uuid()) @db.Uuid
  tenantId             String        @map("tenant_id") @db.Uuid
  tenantSubscriptionId String?       @map("tenant_subscription_id") @db.Uuid
  platformPlanId       String?       @map("platform_plan_id") @db.Uuid
  invoiceNumber        String        @map("invoice_number") @db.VarChar(50)
  amount               Decimal       @db.Decimal(10, 2)
  status               PaymentStatus @default(PENDING)
  razorpayOrderId      String?       @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId    String?       @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature    String?       @map("razorpay_signature") @db.VarChar(255)
  gateway              String?       @db.VarChar(50)
  gatewayStatus        String?       @map("gateway_status") @db.VarChar(50)
  gatewayPayload       Json?         @map("gateway_payload") @db.JsonB
  paidAt               DateTime?     @map("paid_at") @db.Timestamptz(6)
  notes                String?       @db.Text
  issuedAt             DateTime      @default(now()) @map("issued_at") @db.Timestamptz(6)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantSubscription TenantSubscription? @relation(fields: [tenantSubscriptionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, invoiceNumber], name: "uq_tenant_invoice_number")
  @@index([tenantId, status], name: "idx_tenant_invoice_tenant_status")
  @@index([razorpayOrderId], name: "idx_tenant_invoice_order_id")
  @@index([status, paidAt], name: "idx_tenant_invoice_revenue_lookup")
  @@index([platformPlanId, status], name: "idx_tenant_invoice_plan_reporting")
  @@map("tenant_invoices")
}

model WhatsAppLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  memberId  String?  @map("member_id") @db.Uuid
  messageId String?  @map("message_id") @db.VarChar(255)
  type      String   @db.VarChar(50) // e.g. 'EXPIRING_7_DAYS', 'PAYMENT_SUCCESS', 'WELCOME'
  status    String   @default("SENT") @db.VarChar(50) // 'SENT', 'DELIVERED', 'READ', 'FAILED'
  metadata  Json?    @db.JsonB
  
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member    Member?  @relation(fields: [tenantId, memberId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, memberId], name: "idx_whatsapp_log_tenant_member")
  @@index([tenantId, type], name: "idx_whatsapp_log_tenant_type")
  @@index([messageId], name: "idx_whatsapp_log_message_id")
  @@index([tenantId, memberId, type, createdAt], name: "idx_whatsapp_log_throttle")
  @@map("whatsapp_logs")
}
