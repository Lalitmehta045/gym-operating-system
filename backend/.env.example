# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gymos

# ── JWT (required) ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=

# ── Seed credentials (never commit real values) ───────────────────────────────
# Required to create SUPER_ADMIN when none exists:
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=

# Required to create demo owner in non-production seeds:
DEMO_OWNER_PASSWORD=

# ── Razorpay (optional) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── WhatsApp (optional) ─────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Cloudflare R2 storage (optional) ────────────────────────────────────────────
R2_ACCESS_KEY=
R2_SECRET_KEY=
